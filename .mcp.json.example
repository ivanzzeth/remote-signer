{
  "mcpServers": {
    "remote-signer": {
      "command": "npx",
      "args": ["-y", "remote-signer-mcp"],
      "env": {
        "REMOTE_SIGNER_URL": "http://localhost:8548",
        "REMOTE_SIGNER_API_KEY_ID": "admin-key",
        "REMOTE_SIGNER_PRIVATE_KEY": "<your-ed25519-private-key-hex>"
      }
    }
  }
}
