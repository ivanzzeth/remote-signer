# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Compiled binaries (project-specific)
/build/
/remote-signer
/remote-signer-tui
/audit-monitor
/cmd/remote-signer/remote-signer
/cmd/remote-signer-tui/remote-signer-tui
/validate-rules

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Data directory - keep structure, ignore contents (keys, keystores, etc.)
data/*
!data/.gitkeep
!data/keystores/
data/keystores/*
!data/keystores/.gitkeep
!data/keystores/.gitignore
!data/foundry/
data/foundry/*
!data/foundry/.gitkeep
!data/hd-wallets/
data/hd-wallets/*
!data/hd-wallets/.gitkeep
!data/svm/
data/svm/*
!data/svm/.gitkeep

# Configuration files (sensitive)
config.yaml
config.local.yaml
*.pem
.mcp.json

# TLS certificates (generated via scripts/gen-certs.sh)
certs/

# Local deployment temp files
.local-signer-launcher.sh
.local-signer.pid

# Database
remote-signer.db
*.db

# Docker volumes and cache
postgres_data/
forge_cache/
# Rust build artifacts
target/

# Build artifacts
cache/
out/

# JavaScript/TypeScript projects
# Node modules
node_modules/
pkg/js-client/node_modules/
app/metamask-snap/node_modules/

# Build outputs
pkg/js-client/dist/
pkg/mcp-server/build/
app/metamask-snap/dist/
app/metamask-snap/snap.manifest.json.bak

# Package locks (optional - uncomment if you want to ignore them)
# package-lock.json
# pkg/js-client/package-lock.json
# app/metamask-snap/package-lock.json

# TypeScript
*.tsbuildinfo
.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/
*.lcov

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
bin/

# E2E test data (generated keystores, forge cache, binaries, etc.)
e2e/data/
verify-setup-polymarket
/remote-signer-cli
.playwright-cli/
