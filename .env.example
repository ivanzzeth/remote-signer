# Remote Signer Environment Variables
# Copy this file to .env and update values for development
# In production, set these environment variables directly (not via .env)

# =============================================================================
# API Keys (Ed25519 public keys in base64 DER format)
# Generate with: openssl pkey -in public.pem -pubin -outform DER | base64
# =============================================================================
ADMIN_PUBLIC_KEY=MCowBQYDK2VwAyEA...
MY_APP_PUBLIC_KEY=MCowBQYDK2VwAyEA...

# =============================================================================
# EVM Signer Private Keys (hex format, no 0x prefix)
# Generate with: openssl pkey -in private.pem -outform DER | tail -c 32 | xxd -p -c 64
# WARNING: Keep these secret! Never commit to version control.
# =============================================================================
# This is anvil account 0 test key - DO NOT use in production!
# Address: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
EVM_SIGNER_KEY_1=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# =============================================================================
# Notification Services (optional)
# =============================================================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
PUSHOVER_APP_TOKEN=your-pushover-app-token
