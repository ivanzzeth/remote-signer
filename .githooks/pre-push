#!/bin/bash
# pre-push hook — 密钥扫描 + 大文件拦截 + 集成测试（tag 推时跑全部测试）
set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'
VIOLATIONS=0

# 读取推入的 refs（stdin 只能消费一次）
IS_TAG_PUSH=false
RANGES=()
while read -r local_ref local_oid remote_ref remote_oid; do
    ZERO="0000000000000000000000000000000000000000"
    if [ "$local_oid" != "$ZERO" ] && [ "$remote_oid" != "$ZERO" ]; then
        RANGES+=("$remote_oid..$local_oid")
    elif [ "$local_oid" != "$ZERO" ]; then
        # 新分支 — 检查所有 commit
        RANGES+=("$local_oid")
    fi
    if echo "$local_ref" | grep -Eq "^refs/tags/v[0-9]+\.[0-9]+\.[0-9]+"; then
        IS_TAG_PUSH=true
    fi
done

# ─── 1. 密钥扫描（扫描推送范围内的所有 commit）─────────────
echo "→ Scanning pushed commits for secrets..."
SECRET_PATTERNS=(
    'ed25519:[[:space:]]*[0-9a-fA-F]{64,128}'
    'private_key:[[:space:]]*"?0x[0-9a-fA-F]{64}"?'
    'keystore_password:[[:space:]]*"[^"]{8,}"'
    'password:[[:space:]]*"[^"]{8,}"'
    'api_key:[[:space:]]*"?[A-Za-z0-9+/=]{32,}"?'
    '-----BEGIN\s+(RSA|EC|DSA|OPENSSH|PRIVATE)\s+KEY-----'
    '(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{36}'
    'sk-[A-Za-z0-9]{20,}'
)

EXCLUDE_REGEX='(tests/|__tests__/|test_|\.spec\.|mock|fixtures|factories|testdata/|e2e/|\.env\.example|\.example|\.gitignore|node_modules)'

for range in "${RANGES[@]}"; do
    for commit in $(git rev-list "$range" 2>/dev/null); do
        for f in $(git diff --name-only "$commit^" "$commit" 2>/dev/null); do
            echo "$f" | grep -Eq "$EXCLUDE_REGEX" && continue
            content=$(git show "$commit:$f" 2>/dev/null || true)
            for pattern in "${SECRET_PATTERNS[@]}"; do
                match=$(echo "$content" | grep -Pn -- "$pattern" || true)
                if [ -n "$match" ]; then
                    echo -e "${RED}⚠ SECRET in ${f} (commit ${commit:0:8}):${NC}"
                    echo "$match" | head -2
                    VIOLATIONS=$((VIOLATIONS + 1))
                fi
            done
        done
    done
done

if [ $VIOLATIONS -gt 0 ]; then
    echo -e "${RED}❌ Found $VIOLATIONS secret(s). Push rejected.${NC}"
    exit 1
fi
echo "   ✅ No secrets detected."

# ─── 2. 大文件拦截 ──────────────────────────────────────────
echo "→ Checking for large files..."
LARGE_COUNT=0
MAX_SIZE=$((50 * 1024 * 1024))

for range in "${RANGES[@]}"; do
    git rev-list --objects "$range" 2>/dev/null | while read -r sha path; do
        [ -z "$path" ] && continue
        [ -z "$sha" ] && continue
        size=$(git cat-file -s "$sha" 2>/dev/null || echo 0)
        if [ "$size" -gt "$MAX_SIZE" ]; then
            echo -e "${RED}⚠ Large file: $path ($(numfmt --to=iec-i "$size" 2>/dev/null || echo "${size} bytes"))${NC}"
            LARGE_COUNT=$((LARGE_COUNT + 1))
        fi
    done
done

if [ "$LARGE_COUNT" -gt 0 ]; then
    echo -e "${RED}❌ Found $LARGE_COUNT large file(s). Push rejected.${NC}"
    exit 1
fi
echo "   ✅ No large files."

# ─── 3. 测试 ────────────────────────────────────────────────
if [ "$IS_TAG_PUSH" = true ]; then
    echo "→ SemVer tag push detected, running ALL tests..."
    (cd "$REPO_ROOT" && go test -tags integration ./internal/...) || exit 1
    (cd "$REPO_ROOT" && go test -tags integration ./tests/integration/...) || exit 1
else
    echo "→ Running integration tests..."
    (cd "$REPO_ROOT" && go test -tags integration ./tests/integration/...) || exit 1
fi

echo "✅ All pre-push checks passed."
