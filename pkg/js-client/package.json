{
  "name": "@remote-signer/client",
  "version": "1.0.0",
  "description": "JavaScript client library for remote-signer service",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "jest",
    "test:e2e": "jest tests/e2e.test.ts",
    "test:unit": "jest --testPathIgnorePatterns=tests/e2e.test.ts",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "remote-signer",
    "ethereum",
    "signing",
    "ed25519"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^30.2.0",
    "eslint": "^8.0.0",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
