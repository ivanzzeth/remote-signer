{
  "name": "remote-signer-snap",
  "version": "1.0.0",
  "description": "MetaMask Snap for remote-signer service integration",
  "type": "module",
  "main": "dist/bundle.js",
  "scripts": {
    "build": "mm-snap build -s src/index.ts --transpilationMode localAndDeps --eval false --manifest false --writeManifest false && npm run manifest:update-shasum",
    "build:full": "mm-snap build -s src/index.ts --transpilationMode localAndDeps",
    "manifest": "mm-snap manifest",
    "manifest:validate": "mm-snap manifest",
    "manifest:fix": "mm-snap manifest --fix",
    "manifest:update-shasum": "node -e \"const crypto=require('crypto');const fs=require('fs');const manifest=JSON.parse(fs.readFileSync('snap.manifest.json','utf8'));const bundle=fs.readFileSync('dist/bundle.js');const shasum=crypto.createHash('sha256').update(bundle).digest('base64');manifest.source.shasum=shasum;fs.writeFileSync('snap.manifest.json',JSON.stringify(manifest,null,2)+'\\n');\"",
    "serve": "mm-snap serve --port 8549",
    "watch": "mm-snap watch -s src/index.ts --transpilationMode localAndDeps",
    "test": "jest --config jest.config.cjs",
    "test:e2e": "jest --config jest.config.cjs \"tests/*.e2e.test.ts\"",
    "test:unit": "jest --config jest.config.cjs --testPathIgnorePatterns=tests/.*\\.e2e\\.test\\.ts$",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "metamask",
    "snap",
    "remote-signer",
    "ethereum",
    "signing"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivanzzeth/remote-signer.git"
  },
  "dependencies": {
    "@metamask/keyring-api": "^2.0.0",
    "@metamask/snaps-sdk": "^1.0.0",
    "@remote-signer/client": "file:../../pkg/js-client"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/runtime": "^7.28.6",
    "@metamask/snaps-cli": "^1.0.0",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-jest": "^30.2.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}